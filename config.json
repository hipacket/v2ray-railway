{
  "log": { 
    "loglevel": "error",
    "access": "none"
  },
  "inbounds": [
    {
      "port": 8080,
      "listen": "0.0.0.0",
      "protocol": "vless",
      "settings": {
        "clients": [{ "id": "SECRET_UUID_PLACEHOLDER", "level": 0 }],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "ws",
        "wsSettings": {
          "path": "/ray",
          "headers": {
            "Host": "SECRET_HOST_PLACEHOLDER"
          }
        }
      }
    },
    {
      "port": 8081,
      "listen": "0.0.0.0",
      "protocol": "http",
      "settings": {
        "accounts": [
          {
            "user": "admin",
            "pass": "SECRET_PASSWORD_PLACEHOLDER"
          }
        ]
      }
    }
  ],
  "outbounds": [{ "protocol": "freedom", "settings": {} }]
}
